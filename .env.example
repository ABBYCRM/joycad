# JoyCAD — environment configuration
# Copy this file to `.env` and fill in what you use.

# Pick a provider: openai | anthropic | ollama | openrouter | vllm
JOYCAD_LLM_PROVIDER=openai

# Provider keys (fill what you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Ollama (local LLM) — e.g. llama3.1, qwen2.5-coder, deepseek-coder
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# vLLM (local)
VLLM_BASE_URL=http://localhost:8000/v1

# Onshape (https://cad.onshape.com → Developer Tools)
ONSHAPE_ACCESS_KEY=
ONSHAPE_SECRET_KEY=
ONSHAPE_BASE_URL=https://cad.onshape.com

# Fusion 360 (local install + API add-in)
FUSION360_SCRIPT_DIR=

# FreeCAD (headless)
FREECAD_CMD=freecadcmd              # linux; Windows: FreeCADCmd.exe

# CalculiX (FEA solver)
CALCULIX_CMD=ccx

# LinuxCNC
LINUXCNC_INI=

# Logging
JOYCAD_LOG_LEVEL=INFO